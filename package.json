{
  "name": "panjay",
  "version": "1.0.0",
  "description": "Panjay Bot WhatsApp",
  "type": "module",
  "main": "panjayset.ts",
  "scripts": {
    "start": "tsx panjayset.ts",
    "typecheck": "tsc --noEmit",
    "check:no-any": "rg -n \"(:\\s*any\\b|as\\s+any\\b|<any>|Array<any>)\" . -g \"*.ts\" -g \"*.d.ts\" -g \"!node_modules\" && exit 1 || exit 0",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "author": "Panjay",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.4.0",
    "brat-canvas": "^1.0.30",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.7",
    "figlet": "^1.6.0",
    "fluent-ffmpeg": "2.1.2",
    "fs": "^0.0.1-security",
    "https": "^1.0.0",
    "mime-types": "^2.1.35",
    "node-webpmux": "3.2.1",
    "os": "0.1.2",
    "path": "^0.12.7",
    "pg": "^8.21.0",
    "pino": "^8.14.1",
    "readline": "1.3.0",
    "url": "^0.11.0",
    "util": "0.12.5"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
